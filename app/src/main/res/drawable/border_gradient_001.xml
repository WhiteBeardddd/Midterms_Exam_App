<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Border Layer (Black Border) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
            <stroke android:width="2.5dp" android:color="#000000"/> <!-- Black border -->
            <corners android:radius="12dp"/> <!-- Rounded corners -->
        </shape>
    </item>

    <!-- Background Layer (Gradient) -->
    <item android:left="3dp" android:right="3dp" android:top="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="#FBDCDF"
                android:endColor="#F2ADEC"
                android:type="linear"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>

</layer-list>
