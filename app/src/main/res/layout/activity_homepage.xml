<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".display.Homepage">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/gradient_bg_004"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="99dp"
            android:elevation="8dp"
            android:background="@drawable/gradient_bg_002"
            android:orientation="horizontal"
            android:padding="10dp">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="71dp"
                android:layout_height="74dp"
                android:layout_gravity="start|center_vertical"
                android:src="@drawable/beauty_logo"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:gravity="center_vertical"
                android:text="Beautify"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.3"
                android:fontFamily="@font/grand_hotel_regular"
                android:textSize="27sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="start"
            android:orientation="vertical">

            <!-- Featured Products -->
            <TextView
                android:id="@+id/featured_products_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp"
                android:gravity="center_vertical"
                android:text="Featured Products"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/lexend_black"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/featured_recycler"
                android:layout_width="match_parent"
                android:layout_height="412dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:background="#00000000"
                android:clickable="true"
                tools:ignore="InefficientWeight,KeyboardInaccessibleWidget" />


            <!-- Popular Products -->
            <TextView
                android:id="@+id/popular_products_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp"
                android:gravity="center_vertical"
                android:text="Popular Products"
                android:fontFamily="@font/lexend_black"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/popular_recycler"
                android:layout_width="match_parent"
                android:layout_height="412dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:background="#00000000"
                android:clickable="true"
                tools:ignore="InefficientWeight,KeyboardInaccessibleWidget" />


            <!--      PATHS      -->
            <LinearLayout
                android:id="@+id/navigation_bar"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bg_002"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:weightSum="6"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageButton
                    android:id="@+id/toHome"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/border_inv"
                    android:elevation="8dp"
                    android:src="@drawable/home_icon"
                    tools:ignore="ContentDescription,HardcodedText" />

                <ImageButton
                    android:id="@+id/toRatings"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/border_inv"
                    android:elevation="8dp"
                    android:src="@drawable/popular_icon"
                    tools:ignore="ContentDescription,HardcodedText" />

                <ImageButton
                    android:id="@+id/toSkinTypes"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/border_inv"
                    android:elevation="8dp"
                    android:src="@drawable/skin_type_icon"
                    tools:ignore="ContentDescription,HardcodedText" />

                <ImageButton
                    android:id="@+id/toFeatured"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/border_inv"
                    android:elevation="8dp"
                    android:src="@drawable/featured_icon"
                    tools:ignore="ContentDescription" />

                <ImageButton
                    android:id="@+id/toPayment"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/border_inv"
                    android:elevation="8dp"
                    android:src="@drawable/check_out_icon"
                    tools:ignore="ContentDescription" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
