<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".pages.FeaturedProducts">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/gradient_bg_004">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="99dp"
            android:elevation="8dp"
            android:background="@drawable/gradient_bg_002"
            android:orientation="horizontal"
            android:padding="10dp">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="71dp"
                android:layout_height="74dp"
                android:layout_gravity="start|center_vertical"
                android:src="@drawable/beauty_logo"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:gravity="center_vertical"
                android:text="Beautify"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.3"
                android:fontFamily="@font/grand_hotel_regular"
                android:textSize="27sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- Content Section (Takes remaining space) -->
        <LinearLayout
            android:id="@+id/main_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="start"
            android:orientation="vertical"
            tools:ignore="UselessLeaf">
            <!-- Add your main content here -->

            <ImageButton
                android:id="@+id/back_btn"
                android:layout_width="50dp"
                android:layout_height="45dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/back_icon"
                android:backgroundTint="@color/white"
                app:layout_constraintTop_toBottomOf="@id/linearLayout"
                tools:ignore="ContentDescription,MissingConstraints" />

            <!-- Popular Products -->
            <TextView
                android:id="@+id/featured_products_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Featured Products"
                android:textColor="#FFFFFF"
                android:textSize="27sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <ListView
                android:id="@+id/featured_recycler"
                android:layout_width="match_parent"
                android:layout_height="412dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:background="#52000000"
                android:clickable="true"
                tools:ignore="InefficientWeight,KeyboardInaccessibleWidget,NestedWeights" />



        </LinearLayout>

        <!-- Bottom Navigation Bar -->
        <LinearLayout
            android:id="@+id/navigation_bar"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_bg_002"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:gravity="center"
            android:weightSum="6"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/toHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/home_icon"
                tools:ignore="ContentDescription,HardcodedText" />

            <ImageButton
                android:id="@+id/toRatings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/popular_icon"
                tools:ignore="ContentDescription,HardcodedText" />


            <ImageButton
                android:id="@+id/toSkinTypes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/skin_type_icon"
                tools:ignore="ContentDescription,HardcodedText" />

            <ImageButton
                android:id="@+id/toFeatured"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/featured_icon"
                tools:ignore="ContentDescription" />

            <ImageButton
                android:id="@+id/toPayment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/check_out_icon"
                tools:ignore="ContentDescription" />

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>